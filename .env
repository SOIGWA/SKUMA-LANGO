# =============================================================================
# SUKUMA LANGO — Environment Configuration
# CRITICAL: Copy this to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# ---- Server ----
PORT=3000
NODE_ENV=development
# Closed-loop LAN — bind to LAN IP (e.g., 192.168.1.100) or 0.0.0.0
HOST=0.0.0.0

# ---- MySQL Database ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sukuma_lango
DB_USER=sukuma_app
# CHANGE THIS: Use a strong, unique password
DB_PASSWORD=Soigwa1150?

# ---- JWT Configuration ----
# CHANGE THIS: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ea0e28a410c270cc4a56159e82aedae880b253d586253567e209b3a3073f3f62f9da90ff52618fb8ff0acc632e77ee07ac7b6ecf983b276dade9b582495aeb72
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=273d988e6c46e9df23365c7242a41330f73cf6a6f20e592edf35cb4ed1008b8ce29b762aec34e44c8cb422d7d0810e86ca07795faf5c4ead77b7448f23ffadbf
JWT_REFRESH_EXPIRES_IN=24h

# ---- AES-256 Encryption (PII at rest) ----
# CHANGE THIS: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_ENCRYPTION_KEY=ba54b03c6bbddb595a5d1f537e18cb1588df9e2833750746a31ab4c4bdbd42a5
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
AES_IV_SECRET=b697e7096faf4b0c7158953b41c9d1bc

# ---- Bcrypt ----
BCRYPT_SALT_ROUNDS=12

# ---- Rate Limiting ----
# Max login attempts per IP per window
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# Account lockout after N consecutive failures
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MS=1800000

# ---- Logging ----
LOG_LEVEL=info
LOG_DIR=./logs

# ---- Local Pass QR ----
# Secret for signing local pass tokens (different from JWT secret)
QR_PASS_SECRET=3dbd4b37c5f43b13e13cdb32dd9019e1f29172634b325d700d1cd1ae3b993bb4
QR_PASS_EXPIRES_HOURS=12
